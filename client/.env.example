# Supabase Configuration
# Get these values from your Supabase project settings (https://supabase.com)
# Go to: Settings → API → Project URL and API Key (anon/public)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server Configuration
# In local development, you don't need to set this (it defaults to localhost)
# For production (Render), set this to your Render backend URL
VITE_SERVER_URL=https://your-backend-url.com

# Render Backend URL (for keep-alive pings)
# Set this to your Render backend URL to enable keep-alive monitoring
# Example: https://syncpad-io-backend.onrender.com
VITE_RENDER_URL=
